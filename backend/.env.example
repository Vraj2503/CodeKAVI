# ── API Keys & Credentials ──
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ZILLIZ_URI=your-zilliz-uri-here
ZILLIZ_API_KEY=your-zilliz-api-key-here
REDIS_URL=redis://localhost:6379/0
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Optional/CORS Config ──
CORS_ORIGINS=http://localhost:3000

# ── Model Names ──
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=gemini-embedding-2

# ── Bounded cache / limits ──
MAX_CONTENT_CACHE_BYTES=10485760
REPO_SIZE_LIMIT_BYTES=104857600
REPO_FILE_LIMIT=2000

# ── Rate Limiting ──
RATE_LIMIT_IP_RPM=60
RATE_LIMIT_USER_RPM=20

# ── Daily Quotas ──
DAILY_USER_TOKEN_QUOTA=200000
GLOBAL_DAILY_SPEND_LIMIT_USD=5.0
