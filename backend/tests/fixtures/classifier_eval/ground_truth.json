  "_meta": {
    "purpose": "Ground-truth labels for the file role classifier (T4.7).",
    "labeling_notes": [
      "Each entry is a (repo, path, expected_role) triple. expected_role is what",
      "classify_files() SHOULD return for the file at `path` inside `repo`.",
      "Only roles that can be confidently assigned from filename + path + a brief",
      "glance at the source are included. Multi-role cases (e.g. a test file that",
      "is ALSO an entry point) pick the dominant role the classifier would choose.",
      "Defaults to the FIRST matching role in classifier._determine_role — the",
      "classifier picks highest-confidence candidate."
    ],
    "expected_metric": "macro-F1 >= 0.6 across all roles"
  },
